#!/usr/bin/env bash
set -euo pipefail
mkdir -p dist
VERSION=$(./target/x86_64-unknown-linux-musl/release/dotty --version | awk '{print $2}')
ARCHIVE="dist/dotty-v${VERSION}-x86_64-unknown-linux-musl.tar.gz"
tar -czf "$ARCHIVE" -C target/x86_64-unknown-linux-musl/release dotty
sha256sum "$ARCHIVE" > "${ARCHIVE}.sha256"
