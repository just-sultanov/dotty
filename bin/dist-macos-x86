#!/usr/bin/env bash
set -euo pipefail
mkdir -p dist
VERSION=$(./target/x86_64-apple-darwin/release/dotty --version | awk '{print $2}')
ARCHIVE="dist/dotty-v${VERSION}-x86_64-apple-darwin.tar.gz"
tar -czf "$ARCHIVE" -C target/x86_64-apple-darwin/release dotty
shasum -a 256 "$ARCHIVE" > "${ARCHIVE}.sha256"
